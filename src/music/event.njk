---
layout: layout.njk
terminalFile: /assets/terminal/music/event.json
pagination:
  data: allGigEvents
  size: 1
  alias: event
permalink: "{{ event.path }}"
pageStyles:
  - /assets/css/components/music-media-cards.css
  - /assets/css/sections/music-event.css
---

<div class="music-intro">
{% importMd "music/_content/intro/event.md" %}
</div>

<nav class="terminal-path-source" hidden aria-hidden="true">
    <a href="/" title="Jump to: home">/home/fm</a>
    <a href="/music/" title="Jump to: music">/music</a>
    <a href="/music/gigs/" title="Jump to: gigs">/gigs</a>
    <a href="{{ event.listHref }}" title="Jump to: {{ event.listLabel }}">{{ "/" ~ (event.listLabel | lower | replace(" ", "-")) }}</a>
    <span>/{{ event.name or event.date }}</span>
</nav>

{% macro fmtDate(iso) %}
    {% set y = iso.slice(0,4) %}{% set m = iso.slice(5,7) %}{% set d = iso.slice(8,10) %}
    {{ y }}-{{ m }}-{{ d }}
{% endmacro %}

<div class="music-event-grid">
{% for it in event.items %}
<a class="music-event-card" href="{{ it.display1600 }}" target="_blank" rel="noopener">
    <img
        src="{{ it.thumb480 or it.thumb or it.display1600 }}"
        srcset="{{ it.thumb480 or it.thumb or it.display1600 }} 480w, {{ it.thumb960 or it.display1600 }} 960w"
        sizes="(max-width: 600px) 100vw, (max-width: 1200px) 33vw, 25vw"
        alt="{{ it.alt }}"
        width="{{ it.thumb_w or 480 }}"
        height="{{ it.thumb_h or 300 }}"
        loading="lazy" decoding="async">
    <div class="gig-meta">
        <span class="dot">{{ fmtDate(it.date) }}</span>
        {% if event.name %}<span class="dot">{{ event.name }}</span>{% endif %}
        {% if it.seq %}<span class="dot">#{{ it.seq }}</span>{% endif %}
    </div>
</a>
{% endfor %}
</div>

<br>
