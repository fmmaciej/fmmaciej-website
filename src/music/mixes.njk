---
title: FM — /music/mixes
layout: layout.njk
terminalFile: /assets/terminal/music/mixes.json
permalink: /music/mixes/index.html
---

{% from "macros/breadcrumbs.njk" import renderBreadcrumb %}
{% from "macros/music-collections.njk" import renderGroup %}

{{ renderBreadcrumb([
    { href: "/music/", label: "/music" },
    { href: "/music/mixes/", label: "/mixes" }
], "", "mixesBreadcrumb", "groupSuffix") }}

<div class="music-intro">
{% importMd "music/_content/intro/mixes.md" %}
</div>

<style>
    .mix-item {
        display:flex;
        align-items:center;
        gap:20px;
        border:1px solid var(--border);
        border-radius:10px;
        padding:12px;
        text-decoration:none;
        background:var(--bg);
        transition:border-color .2s;
        overflow: hidden;
    }
    .mix-item:hover {
        border-color:var(--muted);
    }
    .mix-item.is-disabled {
        cursor:default;
    }
    .mix-item.is-disabled:hover {
        border-color:var(--border);
    }

    .mix-item img {
        width:200px;
        height:120px;
        object-fit:cover;
        border-radius:6px;
        flex-shrink:0;
        transition: transform 0.3s ease;
    }
    .mix-item:hover img {
        transform: scale(1.05);
    }
    .mix-item.is-disabled:hover img {
        transform:none;
    }

    .mix-item figcaption{
        color:var(--text);
        font-size:1rem;
        line-height:1.4
    }

    .mix-item small{
        color:var(--muted);
        display:block;
        margin-top:6px;
        font-size:.9rem
    }

    @media (max-width:600px){
        .mix-item{
            flex-direction:column;
            align-items:flex-start
        }
        .mix-item img{
            width:100%;
            height:auto;
            max-height:240px
        }
        .mix-item figcaption{
            margin-top:10px
        }
    }
</style>

{% macro renderMixCard(it) %}
    {% set thumb = it.img or (it.url | ytThumb) %}
    {% set isLink = it.url %}
    {% if isLink %}
    <a class="mix-item" href="{{ it.url }}" target="_blank" rel="noopener">
    {% else %}
    <div class="mix-item is-disabled" aria-disabled="true">
    {% endif %}
        {% if thumb %}<img src="{{ thumb }}" alt="Thumbnail for {{ it.alt or it.title or 'mix' }}">{% endif %}

        <figcaption>
            {{ it.title }}
            {% set meta = [] %}
            {% if it.date %}{% set meta = meta.concat([it.date]) %}{% endif %}
            {% if it.duration %}{% set meta = meta.concat([it.duration]) %}{% endif %}
            {% if it.genre %}{% set meta = meta.concat([it.genre]) %}{% endif %}
            {% if it.status %}{% set meta = meta.concat([it.status]) %}{% endif %}
            {% if meta.length %}<small>{{ meta | join(" | ") }}</small>{% endif %}
            {% if it.desc %}<small>{{ it.desc }}</small>{% endif %}
        </figcaption>
    {% if isLink %}
    </a>
    {% else %}
    </div>
    {% endif %}
{% endmacro %}

{# ---- DANE Z GLOBALNEGO PLIKU ---- #}
{% set upcomingItems = mixData.upcomingItems or [] %}
{% set latestItems = mixData.latestItems or [] %}
{% set groups = mixData.groups or [] %}
{% set upcomingGroup = mixData.upcomingGroup %}
{% set latestGroup = mixData.latestGroup %}

{# ---- RENDER: każda grupa = osobny <details> (domyślnie zamknięte) ---- #}
{% call renderGroup(upcomingGroup, upcomingItems | length, "list") %}
    {% if upcomingItems | length %}
        {% for it in upcomingItems %}
        {{ renderMixCard(it) }}
        {% endfor %}
    {% else %}
        <div class="mix-item is-disabled" aria-disabled="true">
            <figcaption>
                No upcoming mixes added yet.
            </figcaption>
        </div>
    {% endif %}
{% endcall %}

{% if latestItems | length %}
{% call renderGroup(latestGroup, latestItems | length, "list") %}
    {% for it in latestItems %}
    {{ renderMixCard(it) }}
    {% endfor %}
{% endcall %}
{% endif %}

{% for group in groups %}
    {% call renderGroup(group, group.items | length, "list") %}
        {% for it in group.items %}
        {{ renderMixCard(it) }}
        {% endfor %}
    {% endcall %}
{% endfor %}

<br>
