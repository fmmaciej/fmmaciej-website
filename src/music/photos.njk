---
title: FM — /music/photos
layout: layout.njk
terminalFile: /assets/terminal/music/photos.json
permalink: /music/photos/index.html
pageStyles:
  - /assets/css/components/music-collections.css
  - /assets/css/components/music-media-cards.css
  - /assets/css/sections/photos.css
pageScripts:
  - /assets/js/pages/page-boot.js
---

{% from "macros/breadcrumbs.njk" import renderBreadcrumb %}
{% from "macros/music-collections.njk" import renderGroup %}

{{ renderBreadcrumb([
    { href: "/music/", label: "/music" },
    { href: "/music/photos/", label: "/photos" }
], "", "photosBreadcrumb", "photosSuffix") }}

<div class="music-intro">
{% importMd "music/_content/intro/photos.md" %}
</div>

{% macro renderPhotoCard(photo, eager) %}
    <div class="music-photo-card">
        <a class="photo-preview" href="{{ photo.display1600 }}" target="_blank" rel="noopener" aria-label="{{ photo.alt }}">
        <img
            src="{{ photo.thumb480 }}"
            srcset="{{ photo.thumb480 }} 480w, {{ photo.thumb960 }} 960w, {{ photo.display1600 }} 1600w"
            sizes="(max-width: 600px) 100vw, (max-width: 1200px) 33vw, 25vw"
            alt="{{ photo.alt }}"
            width="{{ photo.thumb_w }}"
            height="{{ photo.thumb_h }}"
            {% if eager %}loading="eager" fetchpriority="high"{% else %}loading="lazy" fetchpriority="low"{% endif %}
            decoding="async">
        </a>
        <div class="photo-meta">
            <div><span class="photo-label">data:</span> {{ photo.date }}</div>
            <div><span class="photo-label">miejsce:</span> {{ photo.place }}</div>
            <div><span class="photo-label">Autor:</span> {{ photo.author }}</div>
            {% if photo.authorInfo.instagram or photo.authorInfo.facebook or photo.authorInfo.email %}
            <div><span class="photo-label">Kontakt:</span></div>
            <div class="photo-contact-list">
                {% if photo.authorInfo.instagram %}
                <div class="photo-contact-item">
                    <span class="photo-contact-key">ig:</span>
                    <a href="{{ photo.authorInfo.instagram.href }}" target="_blank" rel="noopener">{{ photo.authorInfo.instagram.label }}</a>
                </div>
                {% endif %}
                {% if photo.authorInfo.facebook %}
                <div class="photo-contact-item">
                    <span class="photo-contact-key">fb:</span>
                    <a href="{{ photo.authorInfo.facebook.href }}" target="_blank" rel="noopener">{{ photo.authorInfo.facebook.label }}</a>
                </div>
                {% endif %}
                {% if photo.authorInfo.email %}
                <div class="photo-contact-item">
                    <span class="photo-contact-key">email:</span>
                    <a href="{{ photo.authorInfo.email.href }}">{{ photo.authorInfo.email.label }}</a>
                </div>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
{% endmacro %}

{% set groups = photoData.groups | default([]) %}

{% if groups | length %}
{% for group in groups %}
{% set isFirstGroup = loop.first %}
{% call renderGroup(group, group.count, "grid") %}
    {% for photo in group.items %}
        {% set eager = isFirstGroup and loop.first %}
        {{ renderPhotoCard(photo, eager) }}
    {% endfor %}
{% endcall %}
{% endfor %}
{% else %}
<div class="group">
    <div class="group-items" data-layout="list">
        <div class="group-empty">No photos added yet.</div>
    </div>
</div>
{% endif %}

<br>
