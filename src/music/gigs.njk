---
title: FM — /music/gigs
layout: layout.njk
terminalFile: /assets/terminal/music/gigs.json
permalink: /music/gigs/index.html
pageStyles:
  - /assets/css/components/music-collections.css
  - /assets/css/components/music-media-cards.css
  - /assets/css/sections/gigs.css
pageScripts:
  - /assets/js/pages/page-boot.js
---

{% from "macros/breadcrumbs.njk" import renderBreadcrumb %}
{% from "macros/music-collections.njk" import renderGroup %}

{{ renderBreadcrumb([
    { href: "/music/", label: "/music" },
    { href: "/music/gigs/", label: "/gigs" }
], "", "gigsBreadcrumb", "yearSuffix") }}

<div class="music-intro">
{% importMd "music/_content/intro/gigs.md" %}
</div>

{% macro renderGigCard(ev, eager) %}
    <a class="gig-card" href="{{ ev.path }}" aria-label="{{ ev.cover.alt }}">
        <img
            src="{{ ev.cover.thumb480 }}"
            srcset="{{ ev.cover.thumb480 }} 480w, {{ ev.cover.thumb960 }} 960w"
            sizes="(max-width: 600px) 100vw, (max-width: 1200px) 33vw, 25vw"
            alt="{{ ev.cover.alt }}"
            width="{{ ev.cover.w }}"
            height="{{ ev.cover.h }}"
            {% if eager %}loading="eager" fetchpriority="high"{% else %}loading="lazy" fetchpriority="low"{% endif %}
            decoding="async">
        <div class="gig-meta">
            <div class="gig-date">{{ ev.date }}</div>
            <div class="gig-name">{% if ev.name %}{{ ev.name }}{% else %}&nbsp;{% endif %}</div>
            <div class="gig-count">{{ ev.count }} photo{% if ev.count > 1 %}s{% endif %}</div>
        </div>
    </a>
{% endmacro %}

{# --- zgrupowane dane z _data/gigData.js (korzysta z gigEvents.js) --- #}
{% set groups = gigData.groups | default([]) %}
{% set tbaEvents = gigTbaEvents | default([]) %}
{% set tbaGroup = { name: "To Be Announced", slug: "tba" } %}

{# --- render --- #}
{% call renderGroup(tbaGroup, tbaEvents | length, "grid") %}
    {% if tbaEvents | length %}
    {% for ev in tbaEvents %}
        {% set eager = loop.index0 < 6 %}
        {{ renderGigCard(ev, eager) }}
    {% endfor %}
    {% else %}
    <div class="group-empty">No gigs added yet.</div>
    {% endif %}
{% endcall %}

{% for g in groups %}
{% call renderGroup(g, g.count, "grid") %}
    {% for ev in g.items %}
        {% set eager = loop.index0 < 6 %}
        {{ renderGigCard(ev, eager) }}
    {% endfor %}
{% endcall %}
{% endfor %}

<br>
