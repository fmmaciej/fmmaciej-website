---
title: FM — /projects
layout: layout.njk
terminalFile: /assets/terminal/projects.json
permalink: /projects/index.html
pageStyles:
  - /assets/css/sections/projects.css
---

<div class="page-intro">
{% importMd "projects/_content/intro/index.md" %}
</div>

{% set projectItems = projects.items | default([]) %}
{% set byYear = projectItems | sort(false, attribute="year") | reverse %}

<div class="proj-list">
{% for p in byYear %}
    <article class="proj-item">
        <div class="proj-head">
            <div class="proj-name">{{ p.name }}</div>
            <div class="proj-year">{{ p.year }}</div>
        </div>

        <p class="proj-desc">{{ p.desc }}</p>

        <div class="proj-meta">
            {% if p.stack and p.stack.length %}
                <div class="tags">
                    {% for t in p.stack %}<span class="tag">{{ t }}</span>{% endfor %}
                </div>
            {% endif %}

            <div class="links">
                {% if p.links and p.links.repo %}
                    <a href="{{ p.links.repo }}" target="_blank" rel="noopener">repo</a>
                {% endif %}

                {% if p.links and p.links.docs %}
                    <a href="{{ p.links.docs }}">docs</a>
                {% endif %}

                {% if p.links and p.links.download %}
                    <a href="{{ p.links.download }}">download</a>
                {% endif %}

                {% if p.status %}
                    <span class="status">— {{ p.status }}</span>
                {% endif %}
            </div>
        </div>
    </article>
{% endfor %}
</div>

<br>
