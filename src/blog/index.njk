---
title: FM — /blog
layout: layout.njk
permalink: /blog/index.html
terminalFile: /assets/terminal/blog.json
pageStyles:
  - /assets/css/components/music-collections.css
  - /assets/css/sections/blog.css
---

{% from "macros/music-collections.njk" import renderGroup %}

<div class="page-intro">
{% importMd "blog/_content/intro/index.md" %}
</div>

<nav class="terminal-path-source" hidden aria-hidden="true">
    <a href="/" title="Jump to: home">/home/fm</a>
    <a href="/blog/" title="Jump to: blog">/blog</a>
</nav>

{% set archive = blogArchive or [] %}

{% if archive.length %}
<div class="blog-archive">
    {% for year in archive %}
    {% call renderGroup(year, year.count, "list") %}
        <div class="blog-months">
            {% for month in year.months %}
            {% call renderGroup(month, month.count, "list") %}
                <ul class="blog-list">
                    {% for post in month.items %}
                    <li class="blog-post-item">
                        <div class="blog-post-head">
                            <div class="blog-post-main">
                                <a href="{{ post.url }}">{{ post.title }}</a>
                                {% if post.tags and post.tags.length %}
                                <span class="blog-post-tags">tags: {{ post.tags | join(", ") }}</span>
                                {% endif %}
                            </div>
                            <div class="blog-post-date">{{ post.date | blogDate }}</div>
                        </div>
                        {% if post.description %}<div class="blog-post-desc">{{ post.description }}</div>{% endif %}
                    </li>
                    {% endfor %}
                </ul>
            {% endcall %}
            {% endfor %}
        </div>
    {% endcall %}
    {% endfor %}
</div>
{% else %}
<div class="group-empty">No blog posts added yet.</div>
{% endif %}

<br>
