---
title: FM — /blog
layout: layout.njk
pagination:
    data: collections.blog
    size: 5                # 5 wpisów na stronę
    alias: posts
permalink: "blog/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
terminalFile: /assets/terminal/blog.json
pageStyles:
  - /assets/css/sections/blog.css
---

<div class="page-intro">
{% importMd "blog/_content/intro/index.md" %}
</div>

<nav class="terminal-path-source" hidden aria-hidden="true">
    <a href="/" title="Jump to: home">/home/fm</a>
    <a href="/blog/" title="Jump to: blog">/blog</a>
    {% if pagination.pageNumber > 0 %}
    <span>/page-{{ pagination.pageNumber + 1 }}</span>
    {% endif %}
</nav>

<ul class="blog-list">
    {% for post in posts %}
        <li class="blog-post-item">
        <a href="{{ post.url }}">{{ post.data.title }}</a>
        <div class="blog-post-date">{{ post.date | blogDate }}</div>
        {% if post.data.description %}<div>{{ post.data.description }}</div>{% endif %}
        </li>
    {% endfor %}
</ul>

<nav class="blog-pagination">
    {% if pagination.href.previous %}<a href="{{ pagination.href.previous }}">← nowsze</a>{% endif %}
    {% if pagination.href.previous and pagination.href.next %} · {% endif %}
    {% if pagination.href.next %}<a href="{{ pagination.href.next }}">starsze →</a>{% endif %}
</nav>

<br>
