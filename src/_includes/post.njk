---
layout: layout.njk
---

<article>
    <nav class="terminal-path-source" hidden aria-hidden="true">
        <a href="/" title="Jump to: home">/home/fm</a>
        <a href="/blog/" title="Jump to: blog">/blog</a>
        <span>/{{ title }}</span>
    </nav>
    <header class="blog-entry-header">
        <div class="blog-entry-heading-row">
            <div class="blog-entry-heading-main">
                <h2 class="blog-entry-title">{{ title }}</h2>
                {% if tags and tags.length %}
                <span class="blog-entry-tags">tags: {{ tags | join(", ") }}</span>
                {% endif %}
            </div>
            <div class="blog-entry-date">{{ date | blogDate }}</div>
        </div>
        {% if description %}
        <p class="blog-entry-subtitle">{{ description }}</p>
        {% endif %}
    </header>
    {{ content | safe }}
</article>
