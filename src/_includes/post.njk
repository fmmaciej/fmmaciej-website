{% extends "layout.njk" %}
{% block content %}
<article>
    <nav class="terminal-path-source" hidden aria-hidden="true">
        <a href="/" title="Jump to: home">/home/fm</a>
        <a href="/blog/" title="Jump to: blog">/blog</a>
        <span>/{{ title }}</span>
    </nav>
    <header style="margin-bottom:16px">
        <h1>{{ title }}</h1>
        <p style="color:var(--muted);font-size:14px">
        {{ date | blogDate }}
        {% if tags and tags.length %} • Tags: {{ tags | join(", ") }}{% endif %}
        </p>
        {% if description %}<p>{{ description }}</p>{% endif %}
        <hr style="border:0;border-top:1px solid var(--border)">
    </header>
    {{ content | safe }}
</article>
{% endblock %}
